# LLM Provider 类型: anthropic (默认) 或 openai (如使用 OpenAI 官方、DeepSeek、SiliconFlow、OpenRouter 等)
# LLM_PROVIDER=anthropic

# 1. 若使用 Anthropic 协议 (如 Claude 官方或兼容的中转)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# 2. 若使用 OpenAI 协议 (如 OpenAI 官方、DeepSeek 官方、硅基流动等)
# OPENAI_API_KEY=sk-xxxx...
# OPENAI_BASE_URL=https://api.openai.com/v1

# 语音转文字 API 配置（可选，配置后将优先使用云端 API，无需在本地运行 Whisper 模型）
# 支持 OpenAI, Groq, SiliconFlow 等标准的语音转写接口
# TRANSCRIPTION_API_KEY=sk-...
# TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
# TRANSCRIPTION_MODEL=whisper-1

# 模型自定义 (根据您的 API 填入对应的模型名称，如 deepseek-chat、gpt-4o-mini 或 qwen-plus 等)
CLASSIFY_MODEL=claude-haiku-4-5
MERGE_MODEL=claude-opus-4-8

# 自动合并的置信度门槛:high(默认,稳妥) / medium / low(全自动)
AUTO_MERGE_CONFIDENCE=high

# Obsidian 导出目录(默认 OBVault/乱写)
# VAULT_EXPORT_DIR=/Users/you/path/to/vault/乱写

# 定时导出间隔(分钟),0=仅手动
EXPORT_INTERVAL_MINUTES=0

PORT=8787
