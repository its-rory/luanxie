# ==========================================================================
# 必读:管理员密码(必须配置)
# ==========================================================================
# 安全模型:ADMIN_PASSWORD 为空 → 所有受保护端点锁定、无法登录、也无法经 UI 改密。
# 这是有意为之的安全默认,防止"未配置密码即裸奔"。
# 请在此设置密码(建议至少 6 位,勿用 admin),再启动服务;之后可登录并在「设置」页随时修改。
ADMIN_PASSWORD=

# ==========================================================================
# 反代/部署相关(可选)
# ==========================================================================
# Cookie 的 Secure 标志:auto(默认,按 request.url.scheme)/ always(反代终结 TLS 时强制)/ never
# 反代 + HTTPS 场景推荐设为 always,或将 uvicorn 以 --proxy-headers 启动。
# SESSION_COOKIE_SECURE=auto

# 受信反代 IP(逗号分隔)。只有这里的 IP 才会被信任读取 X-Forwarded-For,
# 否则一律用直连 IP(防伪造头绕过登录失败计数/限频)。例如 Nginx 与本服务同机则填 127.0.0.1。
# TRUSTED_PROXIES=

# ==========================================================================
# LLM 供应商
# ==========================================================================
# LLM_PROVIDER=anthropic

# 1. Anthropic 协议 (Claude 官方或兼容中转)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# 2. OpenAI 协议 (OpenAI / DeepSeek / 硅基流动 / OpenRouter 等)
# OPENAI_API_KEY=sk-xxxx...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ==========================================================================
# 语音转写(可选。配置后优先使用云端 API,无需本地 Whisper 模型)
# 支持 OpenAI、Groq、SiliconFlow 等标准语音转写接口
# ==========================================================================
# TRANSCRIPTION_API_KEY=sk-...
# TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
# TRANSCRIPTION_MODEL=whisper-1

# ==========================================================================
# 模型名(按供应商填对应模型名)
# 老变量 CLASSIFY_MODEL / MERGE_MODEL / TRANSCRIPTION_* 仍兼容,见 server/config.py 的 _FALLBACK_MAPS
# ==========================================================================
CLASSIFY_MODEL=claude-haiku-4-5
MERGE_MODEL=claude-opus-4-8

# 自动合并置信度门槛(也可在「设置」页改):
#   AUTO_MERGE_EXISTING_CONFIDENCE(已有主题): high(默认)/ medium / low / never
#   AUTO_MERGE_NEW_CONFIDENCE     (新主题)  : high(默认)/ medium / low / never
# AUTO_MERGE_EXISTING_CONFIDENCE=medium
# AUTO_MERGE_NEW_CONFIDENCE=high

# ==========================================================================
# 以下两项 Obsidian 导出相关配置 暂未实现(预留,当前无效),后续版本再启用
# ==========================================================================
# VAULT_EXPORT_DIR=/Users/you/path/to/vault/乱写
# EXPORT_INTERVAL_MINUTES=0

PORT=8787